# ─── Copy this file to .env and fill in real values ──────────────────────────
# cp .env.example .env
# NEVER commit .env to git

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ─── DATABASE (PostgreSQL direct connection for LangGraph checkpointer) ────────
DATABASE_URL=postgresql+psycopg://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres

# ─── AI MODELS ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
LLAMAPARSE_API_KEY=your_llamaparse_api_key_here
HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# ─── GITHUB ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token_here

# ─── UPSTASH REDIS ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# ─── ADMIN ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Used to open/close the AI circuit breaker via /admin/circuit/open and /close
ADMIN_SECRET=your_admin_secret_here

# ─── OBSERVABILITY ────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Local development: http://localhost:5173
# Production: https://devselect.yourdomain.com
FRONTEND_URL=http://localhost:5173
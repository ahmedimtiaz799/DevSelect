# DevSelect frontend staging environment template.
#
# Copy this to a private staging env file or hosting-provider env settings.
# Never commit real staging values.
# Staging and production must use different Supabase projects.
# Frontend must use only the staging Supabase anon key.
# Never put service role keys or DATABASE_URL in frontend env.

# Use exact staging HTTPS origins. VITE_API_URL should not include an API path.
VITE_SUPABASE_URL=<staging-supabase-url>
VITE_SUPABASE_ANON_KEY=<staging-anon-key>
VITE_API_URL=<staging-api-origin>

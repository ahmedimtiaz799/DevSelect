# DevSelect backend staging environment template.
#
# Copy this to a private staging env file or hosting-provider env settings.
# Never commit real staging values.
# Staging and production must use different Supabase projects.
# Service role keys and DATABASE_URL must remain backend-side only.
#
# Note: the FastAPI app reads environment variables from the runtime and the
# default .env file. This template documents staging values; configure them in
# your staging host or copy privately as needed.

# Supabase staging project
SUPABASE_URL=<staging-supabase-url>
SUPABASE_ANON_KEY=<staging-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>
SUPABASE_JWT_SECRET=<staging-jwt-secret>

# Staging Postgres direct connection for LangGraph checkpoints
DATABASE_URL=<staging-database-url>

# AI provider
AI_PROVIDER=gemini
GEMINI_API_KEY=<staging-provider-key>
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Model configuration
AGENT1_MODEL=gemini-2.5-flash
AGENT2_MODEL=gemini-2.5-flash
AGENT3_MODEL=gemini-2.5-pro
AGENT3_FALLBACK_MODEL=gemini-2.5-flash
FOLLOW_UP_MODEL=gemini-2.5-flash
AGENT1_MAX_INPUT_CHARS=30000
AGENT2_MAX_INPUT_CHARS=30000
AGENT3_MAX_INPUT_CHARS=25000
AGENT1_MAX_OUTPUT_TOKENS=3200
AGENT2_MAX_OUTPUT_TOKENS=1200
AGENT3_MAX_OUTPUT_TOKENS=2600
FOLLOW_UP_MAX_CONTEXT_CHARS=12000
FOLLOW_UP_MAX_QUESTION_CHARS=2000
FOLLOW_UP_MAX_OUTPUT_TOKENS=700
MAX_USER_INPUT_CHARS=2000
EVALUATION_TIMEZONE=UTC
GEMINI_TIMEOUT_SECONDS=120

# CV parsing and validation
LLAMA_PARSE_TIMEOUT_SECONDS=90
MAX_CV_PDF_PAGES=20
ENABLE_CV_LIKENESS_CHECK=true
CV_LIKENESS_MIN_TEXT_CHARS=300
CV_LIKENESS_MIN_SCORE=3
CV_LIKENESS_MAX_PAGES_TO_SCAN=3
DEV_MOCK_EVALUATION=false

# Budget/rate/circuit controls
DAILY_BUDGET_ENABLED=true
DAILY_USER_EVALUATION_LIMIT=25
DAILY_USER_ESTIMATED_TOKEN_LIMIT=1000000
DAILY_GLOBAL_ESTIMATED_TOKEN_LIMIT=10000000
RATE_LIMIT_FAIL_OPEN=false
CIRCUIT_BREAKER_FAIL_OPEN=false
BUDGET_REDIS_FALLBACK_ENABLED=false

# External services
LLAMAPARSE_API_KEY=<staging-provider-key>
HUGGINGFACE_API_TOKEN=<staging-provider-key>
GITHUB_TOKEN=<staging-github-token>

# Staging Redis / Upstash
UPSTASH_REDIS_REST_URL=<staging-redis-url>
UPSTASH_REDIS_REST_TOKEN=<staging-redis-token>

# Admin and observability
ADMIN_SECRET=<staging-admin-secret>
SENTRY_DSN=<staging-sentry-dsn-or-empty>

# CORS
FRONTEND_URL=<staging-frontend-origin>

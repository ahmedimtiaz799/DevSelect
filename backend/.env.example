# ─── Copy this file to .env and fill in real values ──────────────────────────
# cp .env.example .env
# NEVER commit .env to git

# APPLICATION SECURITY
# Use APP_ENV=production in the deployed backend.
# Admin routes are opt-in and should also be restricted at the network layer.
APP_ENV=development
ADMIN_ROUTES_ENABLED=false
API_DOCS_ENABLED=true
# ─── SUPABASE ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
SUPABASE_JWT_ALGORITHMS=ES256
SUPABASE_JWT_AUDIENCE=authenticated

# ─── DATABASE (PostgreSQL direct connection for LangGraph checkpointer) ────────
DATABASE_URL=postgresql+psycopg://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres

# ─── AI MODELS ────────────────────────────────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AGENT1_MODEL=gemini-2.5-flash
AGENT2_MODEL=gemini-2.5-flash
AGENT3_MODEL=gemini-2.5-pro
AGENT3_FALLBACK_MODEL=gemini-2.5-flash
FOLLOW_UP_MODEL=gemini-2.5-flash
AGENT1_MAX_INPUT_CHARS=30000
AGENT2_MAX_INPUT_CHARS=30000
AGENT3_MAX_INPUT_CHARS=25000
AGENT1_MAX_OUTPUT_TOKENS=3200
AGENT2_MAX_OUTPUT_TOKENS=1200
AGENT3_MAX_OUTPUT_TOKENS=2600
FOLLOW_UP_MAX_CONTEXT_CHARS=12000
FOLLOW_UP_MAX_QUESTION_CHARS=2000
FOLLOW_UP_MAX_OUTPUT_TOKENS=700
MAX_USER_INPUT_CHARS=2000
EVALUATION_TIMEZONE=UTC
GEMINI_TIMEOUT_SECONDS=120
LLAMA_PARSE_TIMEOUT_SECONDS=90
MAX_CV_PDF_PAGES=20
ENABLE_CV_LIKENESS_CHECK=true
CV_LIKENESS_MIN_TEXT_CHARS=300
CV_LIKENESS_MIN_SCORE=3
CV_LIKENESS_MAX_PAGES_TO_SCAN=3
DEV_MOCK_EVALUATION=false
DAILY_BUDGET_ENABLED=false
DAILY_USER_EVALUATION_LIMIT=25
DAILY_USER_ESTIMATED_TOKEN_LIMIT=1000000
DAILY_GLOBAL_ESTIMATED_TOKEN_LIMIT=10000000
RATE_LIMIT_FAIL_OPEN=true
CIRCUIT_BREAKER_FAIL_OPEN=false
BUDGET_REDIS_FALLBACK_ENABLED=true
LLAMAPARSE_API_KEY=your_llamaparse_api_key_here
HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# ─── GITHUB ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token_here

# ─── UPSTASH REDIS ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# ─── ADMIN ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Used to open/close the AI circuit breaker via /admin/circuit/open and /close
# Required only when ADMIN_ROUTES_ENABLED=true.
ADMIN_SECRET=your_admin_secret_here

# ─── OBSERVABILITY ────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Local development: http://localhost:5173
# Production placeholder: https://<production-frontend-domain>
# FRONTEND_URL must be one origin only: no path, query, fragment, or wildcard.
FRONTEND_URL=http://localhost:5173

# Repository metadata
.git
.gitignore

# Real environment files and local secrets
.env
.env.*
**/.env
**/.env.*
!.env.example
!.env.*.example
!**/.env.example
!**/.env.*.example

# Dependency and build directories
**/venv
**/.venv
**/node_modules
**/dist
**/build
**/.vite
**/.parcel-cache
**/.turbo
**/.next

# Python and test caches
**/__pycache__
**/*.py[cod]
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.tox
**/.nox
**/.coverage*
**/htmlcov

# Logs, dumps, exports, and backups
**/*.log
**/logs
**/dumps
**/backups
**/*.sql
**/*.dump
**/*.dump.*
**/*.backup
**/*.bak
**/*.sql.gz
**/*.sql.zip
**/*.sql.bak
**/*_dump.sql
**/*_backup.sql

# Reviewed Supabase SQL sources
!supabase/migrations/*.sql
!supabase/rls_manual_tests.sql

# Private keys and certificates
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.jks
**/*.keystore
**/*.crt
**/*.cer
**/*.der
**/id_rsa*
**/id_ed25519*

# Uploads, reports, screenshots, and archives
**/uploads
**/upload
**/uploaded
**/reports
**/generated-reports
**/report-output
**/screenshots
**/captures
**/capture
**/screenshot*.png
**/screenshot*.jpg
**/screenshot*.jpeg
**/screenshot*.webp
**/capture*.png
**/capture*.jpg
**/capture*.jpeg
**/capture*.webp
**/*.pdf
**/*.doc
**/*.docx
**/*.rtf
**/*.zip
**/*.tar
**/*.tgz
**/*.tar.gz
**/*.7z
**/*.rar

# Browser automation and local browser profiles
**/playwright-report
**/test-results
**/playwright/.auth
**/browser-profile
**/browser-profiles
**/browser-data
**/chrome-profile
**/chrome-profiles
**/chrome-user-data
**/user-data-dir

# Local deployment metadata
**/.vercel
**/.render

# Local temporary and editor artifacts
**/.cache
**/.tmp
**/tmp
**/temp
**/*.tmp
**/*.temp
**/*.cache
**/.vscode
**/.idea
**/.DS_Store
**/Thumbs.db

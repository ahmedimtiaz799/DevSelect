# Repository metadata
.git
.gitignore

# Real environment files and local secrets
.env
.env.*
**/.env
**/.env.*
!.env.example
!.env.*.example
!**/.env.example
!**/.env.*.example

# Dependency and build directories
**/venv
**/.venv
**/node_modules
**/dist
**/build
**/.vite
**/.parcel-cache
**/.turbo
**/.next

# Python and test caches
**/__pycache__
**/*.py[cod]
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.tox
**/.nox
**/.coverage*
**/htmlcov

# Logs, dumps, exports, and backups
**/*.log
**/logs
**/dumps
**/backups
**/*.dump
**/*.dump.*
**/*.backup
**/*.bak
**/*.sql.gz
**/*.sql.zip
**/*.sql.bak
**/*_dump.sql
**/*_backup.sql

# Private keys and certificates
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.jks
**/*.keystore
**/*.crt
**/*.cer
**/*.der
**/id_rsa*
**/id_ed25519*

# Uploads, reports, screenshots, and archives
**/uploads
**/upload
**/uploaded
**/reports
**/generated-reports
**/report-output
**/screenshots
**/screenshot*.png
**/screenshot*.jpg
**/screenshot*.jpeg
**/screenshot*.webp
**/*.pdf
**/*.doc
**/*.docx
**/*.rtf
**/*.zip
**/*.tar
**/*.tgz
**/*.tar.gz
**/*.7z
**/*.rar

# Local temporary and editor artifacts
**/.cache
**/.tmp
**/tmp
**/temp
**/*.tmp
**/*.temp
**/*.cache
**/.vscode
**/.idea
**/.DS_Store
**/Thumbs.db
